# Copie este arquivo para `.streamlit/secrets.toml` no uso local.
# No Streamlit Community Cloud, cadastre estes valores em App > Settings > Secrets.
#
# IMPORTANTE:
# - Não use a senha normal do Gmail.
# - Ative verificação em duas etapas na conta Google.
# - Gere uma "Senha de app" e use essa senha de app em `smtp_password`.

[email]
smtp_host = "smtp.gmail.com"
smtp_port = 587
smtp_user = "labcim.manager@gmail.com"
smtp_password = "COLE_AQUI_A_SENHA_DE_APP_DO_GOOGLE"
smtp_from = "LabCim Manager <labcim.manager@gmail.com>"
smtp_tls = true

# Banco de dados de produção/beta
# Use apenas no Streamlit Cloud ou em ambientes que tenham PostgreSQL externo.
# Não use credenciais reais neste arquivo de exemplo.
#
# Formato top-level aceito no Streamlit Cloud
# DATABASE_URL = "postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=require"
#
# Cloudflare R2 para arquivos persistentes em produção/beta.
# O bucket deve permanecer privado. Não use credenciais reais neste exemplo.
#
# R2_ACCOUNT_ID = "SEU_ACCOUNT_ID"
# R2_ENDPOINT_URL = "https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com"
# R2_ACCESS_KEY_ID = "SEU_ACCESS_KEY_ID"
# R2_SECRET_ACCESS_KEY = "SEU_SECRET_ACCESS_KEY"
# R2_BUCKET = "labcim-manager-arquivos"
#
# Também são aceitos:
# [database]
# url = "postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=require"
#
# [r2]
# R2_ACCOUNT_ID = "SEU_ACCOUNT_ID"
# R2_ENDPOINT_URL = "https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com"
# R2_ACCESS_KEY_ID = "SEU_ACCESS_KEY_ID"
# R2_SECRET_ACCESS_KEY = "SEU_SECRET_ACCESS_KEY"
# R2_BUCKET = "labcim-manager-arquivos"
